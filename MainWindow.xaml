<Window x:Class="breakout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:breakout"
        mc:Ignorable="d"
        Title="Breackdown" Height="500" Width="800"
        ResizeMode = "NoResize"
        WindowStartupLocation="CenterScreen"
        Background = "#0a0a0a">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111111" BorderBrush="#222222" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="SCORE" Foreground="#555555" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Name="ScoreText" Text="0" Foreground="#7eb8f7" FontSize="20" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>

                <Rectangle Width="1" Height="24" Fill="#222222" Margin="30,0"/>

                <TextBlock Text="SPEED" Foreground="#555555" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Name="SpeedText" Text="1" Foreground="White" FontSize="20" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>

                <Rectangle Width="1" Height="24" Fill="#222222" Margin="30,0"/>

                <TextBlock Text="LIVES" Foreground="#555555" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Name="LivesText" Text="3" Foreground="White" FontSize="20" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Canvas Name="GameCanvas" Grid.Row="1" Background="#000000"/>

        <Border Grid.Row="2" Background="#111111" BorderBrush="#222222" BorderThickness="0,1,0,0">
            <StackPanel Name="LivesPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
