<Window x:Class="breakout.GameOverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Over"
        Height="250"
        Width="300"
        WindowStartupLocation="CenterScreen"
        Background="Black">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

        <TextBlock Name="ResultText"
                   FontSize="20"
                   Margin="0,20"
                   TextAlignment="Center"
                   Foreground="White"/>

        <Button Content="Restart Game"
                Width="150"
                Margin="10"
                Click="Restart_Click"
                Background="White"/>

        <Button Content="Leaderboard"
                Width="150"
                Margin="10"
                Click="Table_Click"
                Background="White"/>

    </StackPanel>
</Window>